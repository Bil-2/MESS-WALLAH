{
  "name": "mess-wallah-backend",
  "version": "1.0.0",
  "description": "Backend API for MESS WALLAH - Student Mess Booking Platform",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:mongo": "../start-mongodb.sh && npm run dev",
    "start:mongo": "../start-mongodb.sh && npm start",
    "mongo:start": "brew services start mongodb/brew/mongodb-community",
    "mongo:stop": "brew services stop mongodb/brew/mongodb-community",
    "mongo:restart": "brew services restart mongodb/brew/mongodb-community",
    "mongo:status": "brew services list | grep mongodb"
  },
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.5.0",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "express-validator": "^7.0.1",
    "cors": "^2.8.5",
    "helmet": "^7.0.0",
    "morgan": "^1.10.0",
    "express-rate-limit": "^6.10.0",
    "dotenv": "^16.3.1",
    "cloudinary": "^1.40.0",
    "multer": "^1.4.5-lts.1",
    "multer-storage-cloudinary": "^4.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "keywords": [
    "mess",
    "booking",
    "student",
    "food",
    "api"
  ],
  "author": "MESS WALLAH Team",
  "license": "MIT"
}