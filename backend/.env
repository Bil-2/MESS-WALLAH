SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Stripe Configuration (Optional)
STRIPE_SECRET_KEY=your_stripe_secret_key_here

# Razorpay Configuration (Optional)
RAZORPAY_KEY_ID=your_razorpay_key_id
